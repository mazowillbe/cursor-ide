
PORT=3001
HOST=127.0.0.1
# CORS_ORIGIN=https://your-frontend.onrender.com  # For production when frontend is on different origin
# USE_SUPABASE_FILES=true  # Persist workspace files to Supabase (enables multi-user on Render)
WORKSPACE_ROOT=./workspaces
OPENCODE_PATH=opencode
# Default model: use Gemini (google/...) if you added Gemini API key in opencode auth login
# Run "opencode models google" to list available Gemini models
OPENCODE_DEFAULT_MODEL=opencode/minimax-m2.5-free
# OpenCode run --format json outputs JSONL (tool_use, text, etc.) for easy extraction.
# Set OPENCODE_USE_JSON=0 to use legacy text mode (regex parsing) if JSON is unsupported.
# OPENCODE_USE_JSON=1

# Set DEBUG_THINKING=1 to log raw events when using thinking models (Gemini 3, Kimi K2 Thinking) - helps debug if thinking isn't shown
# DEBUG_THINKING=0

# OpenCode Zen API key (bearer token) - for free Zen models like minimax-m2.5-free, glm-5-free, gpt-5-nano
# Get from https://opencode.ai/auth - set this OR GEMINI_API_KEY for the AI agent
OPENCODE_ZEN_API_KEY=

# Deployment: avoid OOM (exit 137). Set NODE_OPTIONS=--max-old-space-size=896 and give container 1.5–2 GB RAM.
# NODE_OPTIONS=--max-old-space-size=896

# Optional: for describe-image (vision) and conversation summarizer. edit_file, title, project name now use OpenCode.
# GEMINI_API_KEY=your-gemini-api-key

# Optional overrides for OpenCode subagent models (default: OPENCODE_DEFAULT_MODEL)
# OPENCODE_TITLE_MODEL=opencode/minimax-m2.5-free
# OPENCODE_PROJECT_NAME_MODEL=opencode/minimax-m2.5-free
# OPENCODE_APPLY_MODEL=opencode/minimax-m2.5-free
# OPENCODE_REAPPLY_MODEL=opencode/minimax-m2.5-free

# Supabase (required for auth and persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: for Supabase CLI (supabase link, db push, etc.) when the AI builds full-stack apps.
# Get from https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
